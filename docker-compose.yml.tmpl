# ── SwiftDeploy — generated by `swiftdeploy init` — DO NOT EDIT BY HAND ──

services:

  # ── Application service ─────────────────────────────────────────────────
  service:
    image: {{ service_image }}
    container_name: swiftdeploy-service
    restart: {{ restart_policy }}

    environment:
      - MODE={{ mode }}
      - APP_VERSION={{ version }}
      - APP_PORT={{ service_port }}

    networks:
      - {{ network_name }}

    volumes:
      - {{ log_volume }}:/logs

    # Healthcheck against the internal port (never exposed to host)
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:{{ service_port }}/healthz || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 15s

    # Security hardening: non-root, drop all Linux capabilities
    user: "1001:1001"
    cap_drop:
      - ALL
    cap_add: []
    security_opt:
      - no-new-privileges:true
    read_only: false

    # NOTE: service port is NOT mapped to the host — all traffic via nginx
    expose:
      - "{{ service_port }}"

  # ── Nginx reverse proxy ──────────────────────────────────────────────────
  nginx:
    image: {{ nginx_image }}
    container_name: swiftdeploy-nginx
    restart: {{ restart_policy }}

    ports:
      - "{{ nginx_port }}:{{ nginx_port }}"

    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - {{ log_volume }}:/var/log/nginx

    networks:
      - {{ network_name }}

    depends_on:
      service:
        condition: service_healthy

# ── Network ──────────────────────────────────────────────────────────────────
networks:
  {{ network_name }}:
    driver: {{ network_driver }}

# ── Volumes ───────────────────────────────────────────────────────────────────
volumes:
  {{ log_volume }}:
    driver: local
