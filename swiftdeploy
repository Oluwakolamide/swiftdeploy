#!/usr/bin/env python3
"""
swiftdeploy — declarative container deployment CLI
Reads manifest.yaml and manages the full stack lifecycle.

Usage:
  swiftdeploy init
  swiftdeploy validate
  swiftdeploy deploy
  swiftdeploy promote [canary|stable]
  swiftdeploy teardown [--clean]
"""

import sys
import os
import re
import time
import socket
import subprocess
import urllib.request
import urllib.error
import json

# ── Dependency check ─────────────────────────────────────────────────────────
try:
    import yaml
except ImportError:
    print("[ERROR] PyYAML not installed. Run: pip install pyyaml")
    sys.exit(1)


# ── Constants ─────────────────────────────────────────────────────────────────
MANIFEST_PATH    = "manifest.yaml"
NGINX_CONF       = "nginx.conf"
COMPOSE_FILE     = "docker-compose.yml"
NGINX_TEMPLATE   = "templates/nginx.conf.tmpl"
COMPOSE_TEMPLATE = "templates/docker-compose.yml.tmpl"

CYAN   = "\033[96m"
GREEN  = "\033[92m"
RED    = "\033[91m"
YELLOW = "\033[93m"
BOLD   = "\033[1m"
RESET  = "\033[0m"


# ── Output helpers ────────────────────────────────────────────────────────────
def banner(text):
    print(f"\n{BOLD}{CYAN}▶  {text}{RESET}")

def ok(msg):
    print(f"  {GREEN}✔{RESET}  {msg}")

def warn(msg):
    print(f"  {YELLOW}⚠{RESET}  {msg}")

def fail(msg):
    print(f"  {RED}✘{RESET}  {msg}")

def die(msg, code=1):
    fail(msg)
    sys.exit(code)


# ── Shell helper ──────────────────────────────────────────────────────────────
def run(cmd, capture=False, check=True, silent=False):
    """Execute a shell command and return the CompletedProcess."""
    kwargs = dict(shell=True, text=True)
    if capture or silent:
        kwargs["capture_output"] = True
    result = subprocess.run(cmd, **kwargs)
    if check and result.returncode != 0:
        if silent:
            raise subprocess.CalledProcessError(result.returncode, cmd,
                                                result.stdout, result.stderr)
    return result


# ── Manifest helpers ──────────────────────────────────────────────────────────
def load_manifest():
    """Load manifest.yaml and return as dict."""
    with open(MANIFEST_PATH) as f:
        data = yaml.safe_load(f)
    if not isinstance(data, dict):
        die("manifest.yaml is empty or not a valid YAML mapping.")
    return data


def build_context(manifest):
    """Build template variable context from manifest dict."""
    svc  = manifest.get("services", {})
    ngx  = manifest.get("nginx",    {})
    net  = manifest.get("network",  {})
    vols = manifest.get("volumes",  {})

    return {
        "service_image":   str(svc.get("image",          "swift-deploy-1-node:latest")),
        "service_port":    str(svc.get("port",           3000)),
        "service_name":    "service",                               # compose service name
        "mode":            str(svc.get("mode",           "stable")),
        "version":         str(svc.get("version",        "1.0.0")),
        "restart_policy":  str(svc.get("restart_policy", "unless-stopped")),
        "nginx_image":     str(ngx.get("image",          "nginx:latest")),
        "nginx_port":      str(ngx.get("port",           8080)),
        "proxy_timeout":   str(ngx.get("proxy_timeout",  30)),
        "network_name":    str(net.get("name",           "swiftdeploy-net")),
        "network_driver":  str(net.get("driver_type",   "bridge")),
        "log_volume":      str(vols.get("logs",          "swiftdeploy-logs")),
    }


# ── Template renderer ─────────────────────────────────────────────────────────
def render_template(path, ctx):
    """
    Render a template file by substituting {{ key }} placeholders.
    Nginx $variables are left untouched (they use a different delimiter).
    """
    if not os.path.exists(path):
        die(f"Template not found: {path}")
    with open(path) as f:
        content = f.read()

    def replace(match):
        key = match.group(1).strip()
        if key not in ctx:
            warn(f"Unknown template variable: {key!r}")
            return match.group(0)
        return ctx[key]

    return re.sub(r"\{\{\s*([\w]+)\s*\}\}", replace, content)


# ── Subcommands ───────────────────────────────────────────────────────────────

# ─ init ───────────────────────────────────────────────────────────────────────
def cmd_init():
    banner("swiftdeploy init")

    manifest = load_manifest()
    ctx      = build_context(manifest)

    # Generate nginx.conf
    nginx_content = render_template(NGINX_TEMPLATE, ctx)
    with open(NGINX_CONF, "w") as f:
        f.write(nginx_content)
    ok(f"Generated  {NGINX_CONF}  (nginx port {ctx['nginx_port']} → service port {ctx['service_port']})")

    # Generate docker-compose.yml
    compose_content = render_template(COMPOSE_TEMPLATE, ctx)
    with open(COMPOSE_FILE, "w") as f:
        f.write(compose_content)
    ok(f"Generated  {COMPOSE_FILE}  (mode={ctx['mode']}, version={ctx['version']})")

    print(f"\n  {BOLD}Init complete.{RESET} Edit manifest.yaml and re-run to regenerate.\n")


# ─ validate ───────────────────────────────────────────────────────────────────
def cmd_validate():
    banner("swiftdeploy validate — 5 pre-flight checks")
    passed, failed_count = 0, 0

    def check(label, fn):
        nonlocal passed, failed_count
        try:
            success, detail = fn()
        except Exception as exc:
            success, detail = False, str(exc)

        if success:
            ok(f"[PASS]  {label}")
            passed += 1
        else:
            fail(f"[FAIL]  {label}")
            failed_count += 1

        if detail:
            indent = "         "
            for line in detail.splitlines():
                print(f"{indent}{line}")

    # ── Check 1: manifest.yaml exists and is valid YAML ───────────────────
    def check_manifest():
        if not os.path.exists(MANIFEST_PATH):
            return False, "File not found."
        with open(MANIFEST_PATH) as f:
            raw = yaml.safe_load(f)
        if raw is None or not isinstance(raw, dict):
            return False, "File is empty or not a valid YAML mapping."
        return True, f"Parsed OK ({len(raw)} top-level keys)."

    # ── Check 2: All required fields present and non-empty ────────────────
    def check_fields():
        m = load_manifest()
        required = {
            "services.image":       m.get("services", {}).get("image"),
            "services.port":        m.get("services", {}).get("port"),
            "nginx.image":          m.get("nginx",    {}).get("image"),
            "nginx.port":           m.get("nginx",    {}).get("port"),
            "network.name":         m.get("network",  {}).get("name"),
            "network.driver_type":  m.get("network",  {}).get("driver_type"),
        }
        missing = [k for k, v in required.items() if v is None or v == ""]
        if missing:
            return False, "Missing or empty: " + ", ".join(missing)
        lines = [f"{k} = {v}" for k, v in required.items()]
        return True, "\n".join(lines)

    # ── Check 3: Docker image exists locally ──────────────────────────────
    def check_image():
        m     = load_manifest()
        image = m.get("services", {}).get("image", "")
        result = run(f"docker image inspect {image}", capture=True, check=False)
        if result.returncode != 0:
            return False, (
                f"Image '{image}' not found locally.\n"
                f"Build it with:  docker build -t {image} ."
            )
        return True, f"Image '{image}' present locally."

    # ── Check 4: Nginx port not already bound ─────────────────────────────
    def check_port():
        m    = load_manifest()
        port = int(m.get("nginx", {}).get("port", 8080))
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            s.settimeout(1)
            in_use = s.connect_ex(("127.0.0.1", port)) == 0
        if in_use:
            return False, f"Port {port} is already bound on this host."
        return True, f"Port {port} is free."

    # ── Check 5: Generated nginx.conf is syntactically valid ──────────────
    def check_nginx_syntax():
        if not os.path.exists(NGINX_CONF):
            return False, f"'{NGINX_CONF}' not found — run 'swiftdeploy init' first."
        abs_conf = os.path.abspath(NGINX_CONF)
        result = run(
            f"docker run --rm "
            f"-v {abs_conf}:/etc/nginx/conf.d/default.conf:ro "
            f"nginx:latest nginx -t 2>&1",
            capture=True, check=False
        )
        output = (result.stdout + result.stderr).strip()
        if result.returncode != 0:
            return False, f"nginx -t output:\n{output}"
        return True, "nginx -t passed."

    check("manifest.yaml exists and is valid YAML",          check_manifest)
    check("All required fields are present and non-empty",   check_fields)
    check("Docker image referenced in manifest exists locally", check_image)
    check("Nginx port is not already bound on the host",     check_port)
    check("Generated nginx.conf is syntactically valid",     check_nginx_syntax)

    print()
    total = passed + failed_count
    color = GREEN if failed_count == 0 else RED
    print(f"  {color}{BOLD}Result: {passed}/{total} checks passed.{RESET}\n")

    if failed_count > 0:
        sys.exit(1)


# ─ deploy ─────────────────────────────────────────────────────────────────────
def cmd_deploy():
    banner("swiftdeploy deploy")

    cmd_init()

    print()
    banner("Bringing up stack …")
    run("docker compose up -d")

    manifest = load_manifest()
    port     = int(manifest.get("nginx", {}).get("port", 8080))
    url      = f"http://localhost:{port}/healthz"

    print(f"\n  Waiting for service at {url} (60 s timeout) …\n")
    deadline = time.time() + 60

    while time.time() < deadline:
        try:
            with urllib.request.urlopen(url, timeout=3) as resp:
                if resp.status == 200:
                    body = json.loads(resp.read())
                    ok(f"Health check passed!  uptime={body.get('uptime', '?')}s")
                    print(f"\n  {GREEN}{BOLD}Stack deployed successfully.{RESET}\n")
                    return
        except Exception:
            pass
        sys.stdout.write(".")
        sys.stdout.flush()
        time.sleep(2)

    print()
    die("Health check timed out after 60 seconds. Check: docker compose logs")


# ─ promote ────────────────────────────────────────────────────────────────────
def cmd_promote(mode):
    if mode not in ("stable", "canary"):
        die(f"Invalid mode '{mode}'. Use: swiftdeploy promote [canary|stable]")

    banner(f"swiftdeploy promote → {mode}")

    # ── 1. Update mode in manifest.yaml in-place ──────────────────────────
    with open(MANIFEST_PATH) as f:
        content = f.read()

    manifest = yaml.safe_load(content)
    current  = manifest.get("services", {}).get("mode", "stable")

    if current == mode:
        warn(f"Already in '{mode}' mode — nothing to do.")
        return

    # Replace mode field value, preserving surrounding YAML whitespace
    if re.search(r"^\s+mode\s*:", content, re.MULTILINE):
        updated = re.sub(
            r"^(\s+mode\s*:\s*)\S+",
            lambda m: m.group(1) + mode,
            content,
            flags=re.MULTILINE,
        )
    else:
        # mode field absent — inject it under services:
        updated = re.sub(
            r"(^services\s*:.*?)(\n\S)",
            lambda m: m.group(1) + f"\n  mode: {mode}" + m.group(2),
            content,
            flags=re.DOTALL,
        )

    with open(MANIFEST_PATH, "w") as f:
        f.write(updated)
    ok(f"manifest.yaml updated:  mode = {current} → {mode}")

    # ── 2. Regenerate docker-compose.yml ──────────────────────────────────
    new_manifest = load_manifest()
    ctx          = build_context(new_manifest)
    compose_out  = render_template(COMPOSE_TEMPLATE, ctx)
    with open(COMPOSE_FILE, "w") as f:
        f.write(compose_out)
    ok("docker-compose.yml regenerated with new MODE env var.")

    # ── 3. Rolling restart of service container only ──────────────────────
    print()
    banner("Restarting service container …")
    run("docker compose up -d --no-deps --force-recreate service")

    # ── 4. Confirm mode via /healthz ──────────────────────────────────────
    port = int(new_manifest.get("nginx", {}).get("port", 8080))
    url  = f"http://localhost:{port}/healthz"

    print(f"\n  Verifying mode switch at {url} …\n")
    time.sleep(3)

    deadline = time.time() + 30
    while time.time() < deadline:
        try:
            req = urllib.request.Request(url)
            with urllib.request.urlopen(req, timeout=3) as resp:
                if resp.status == 200:
                    x_mode  = resp.headers.get("X-Mode", "stable")
                    body    = json.loads(resp.read())
                    uptime  = body.get("uptime", "?")

                    if mode == "canary":
                        if x_mode == "canary":
                            ok(f"Mode confirmed: canary  (X-Mode: canary ✔)  uptime={uptime}s")
                        else:
                            warn(f"Service is up but X-Mode header missing. uptime={uptime}s")
                    else:
                        ok(f"Mode confirmed: stable  uptime={uptime}s")

                    print(f"\n  {GREEN}{BOLD}Promotion to '{mode}' complete.{RESET}\n")
                    return
        except Exception:
            pass
        sys.stdout.write(".")
        sys.stdout.flush()
        time.sleep(2)

    print()
    die("Could not confirm mode switch within 30 seconds.")


# ─ teardown ───────────────────────────────────────────────────────────────────
def cmd_teardown(clean=False):
    banner("swiftdeploy teardown")

    run("docker compose down --volumes --remove-orphans", check=False)
    ok("Containers, networks, and named volumes removed.")

    if clean:
        for path in [NGINX_CONF, COMPOSE_FILE]:
            if os.path.exists(path):
                os.remove(path)
                ok(f"Deleted generated config: {path}")
        print(f"\n  {GREEN}{BOLD}Clean teardown complete.{RESET}\n")
    else:
        print(f"\n  {BOLD}Teardown complete.{RESET}  "
              f"(Pass --clean to also delete generated configs)\n")


# ── Entry point ───────────────────────────────────────────────────────────────
USAGE = f"""
{BOLD}swiftdeploy{RESET} — declarative container deployment tool

{BOLD}Usage:{RESET}
  ./swiftdeploy init
  ./swiftdeploy validate
  ./swiftdeploy deploy
  ./swiftdeploy promote [canary|stable]
  ./swiftdeploy teardown [--clean]

{BOLD}Commands:{RESET}
  init        Parse manifest.yaml → generate nginx.conf + docker-compose.yml
  validate    Run 5 pre-flight checks (exit non-zero on any failure)
  deploy      Run init, start stack, block until healthy or 60 s timeout
  promote     Switch deployment mode with rolling restart; confirm via /healthz
  teardown    Stop and remove all containers, networks, volumes
                --clean  also deletes generated config files
"""

def main():
    args = sys.argv[1:]

    if not args or args[0] in ("-h", "--help", "help"):
        print(USAGE)
        sys.exit(0)

    cmd = args[0]

    if cmd == "init":
        cmd_init()

    elif cmd == "validate":
        cmd_validate()

    elif cmd == "deploy":
        cmd_deploy()

    elif cmd == "promote":
        if len(args) < 2:
            die("Usage: swiftdeploy promote [canary|stable]")
        cmd_promote(args[1])

    elif cmd == "teardown":
        cmd_teardown(clean="--clean" in args)

    else:
        fail(f"Unknown command: {cmd!r}")
        print(USAGE)
        sys.exit(1)


if __name__ == "__main__":
    main()
