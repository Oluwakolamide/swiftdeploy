#!/usr/bin/env python3
"""
swiftdeploy — declarative container deployment CLI (Stage 4B)
Adds OPA policy gating, live status dashboard, and audit report generation.

Usage:
  ./swiftdeploy init
  ./swiftdeploy validate
  ./swiftdeploy deploy
  ./swiftdeploy promote [canary|stable]
  ./swiftdeploy status
  ./swiftdeploy audit
  ./swiftdeploy teardown [--clean]
"""

import sys
import os
import re
import time
import json
import socket
import shutil
import subprocess
import urllib.request
import urllib.error

try:
    import yaml
except ImportError:
    print("[ERROR] PyYAML not installed. Run: pip install pyyaml")
    sys.exit(1)

# Constants
MANIFEST_PATH    = "manifest.yaml"
NGINX_CONF       = "nginx.conf"
COMPOSE_FILE     = "docker-compose.yml"
NGINX_TEMPLATE   = "templates/nginx.conf.tmpl"
COMPOSE_TEMPLATE = "templates/docker-compose.yml.tmpl"
POLICIES_DIR     = "policies"
HISTORY_FILE     = "history.jsonl"
OPA_URL          = "http://localhost:8181"
STATUS_INTERVAL  = 5   # seconds between status refreshes

CYAN   = "\033[96m"
GREEN  = "\033[92m"
RED    = "\033[91m"
YELLOW = "\033[93m"
BOLD   = "\033[1m"
DIM    = "\033[2m"
RESET  = "\033[0m"


# Output helpers
def banner(text):
    print(f"\n{BOLD}{CYAN}▶  {text}{RESET}")

def ok(msg):
    print(f"  {GREEN}✔{RESET}  {msg}")

def warn(msg):
    print(f"  {YELLOW}⚠{RESET}  {msg}")

def fail(msg):
    print(f"  {RED}✘{RESET}  {msg}")

def die(msg, code=1):
    fail(msg)
    sys.exit(code)


# Shell helper
def run(cmd, capture=False, check=True, silent=False):
    kwargs = dict(shell=True, text=True)
    if capture or silent:
        kwargs["capture_output"] = True
    result = subprocess.run(cmd, **kwargs)
    if check and result.returncode != 0 and not silent:
        pass
    return result


# Manifest helpers
def load_manifest():
    with open(MANIFEST_PATH) as f:
        data = yaml.safe_load(f)
    if not isinstance(data, dict):
        die("manifest.yaml is empty or not a valid YAML mapping.")
    return data


def build_context(manifest):
    svc  = manifest.get("services", {})
    ngx  = manifest.get("nginx",    {})
    net  = manifest.get("network",  {})
    vols = manifest.get("volumes",  {})
    return {
        "service_image":   str(svc.get("image",          "swift-deploy-1-node:latest")),
        "service_port":    str(svc.get("port",           3000)),
        "service_name":    "service",
        "mode":            str(svc.get("mode",           "stable")),
        "version":         str(svc.get("version",        "1.0.0")),
        "restart_policy":  str(svc.get("restart_policy", "unless-stopped")),
        "nginx_image":     str(ngx.get("image",          "nginx:latest")),
        "nginx_port":      str(ngx.get("port",           8080)),
        "proxy_timeout":   str(ngx.get("proxy_timeout",  30)),
        "network_name":    str(net.get("name",           "swiftdeploy-net")),
        "network_driver":  str(net.get("driver_type",   "bridge")),
        "log_volume":      str(vols.get("logs",          "swiftdeploy-logs")),
    }


def render_template(path, ctx):
    if not os.path.exists(path):
        die(f"Template not found: {path}")
    with open(path) as f:
        content = f.read()
    def replace(match):
        key = match.group(1).strip()
        return ctx.get(key, match.group(0))
    return re.sub(r"\{\{\s*([\w]+)\s*\}\}", replace, content)


# OPA helpers
def _opa_post(path, input_data, timeout=5):
    """
    POST to OPA REST API. Returns parsed JSON response.
    Raises informative exceptions for distinct failure modes.
    """
    url     = f"{OPA_URL}/v1/data/{path}"
    payload = json.dumps({"input": input_data}).encode()
    req     = urllib.request.Request(
        url, data=payload,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return json.loads(resp.read())
    except urllib.error.URLError as e:
        if "Connection refused" in str(e) or "timed out" in str(e):
            raise ConnectionError(f"OPA unreachable at {OPA_URL} — is the stack running?")
        raise RuntimeError(f"OPA network error: {e}")
    except Exception as e:
        raise RuntimeError(f"OPA query failed: {e}")


def query_opa_domain(domain, input_data):
    """
    Query a single OPA policy domain.
    Returns a dict: {"allow": bool, "reason": str, "domain": str}
    Never crashes — maps every failure mode to a distinct human-readable result.
    """
    try:
        resp   = _opa_post(f"swiftdeploy/{domain}/decision", input_data)
        result = resp.get("result", {})
        if result is None:
            return {
                "allow":  False,
                "reason": f"OPA returned empty result for domain '{domain}' — policy may not be loaded",
                "domain": domain,
                "error":  True,
            }
        return {
            "allow":  bool(result.get("allow", False)),
            "reason": result.get("reason", "(no reason provided)"),
            "domain": domain,
            "error":  False,
        }
    except ConnectionError as e:
        return {"allow": False, "reason": str(e),                          "domain": domain, "error": True}
    except RuntimeError as e:
        return {"allow": False, "reason": str(e),                          "domain": domain, "error": True}
    except Exception as e:
        return {"allow": False, "reason": f"Unexpected OPA error: {e}",    "domain": domain, "error": True}


def print_opa_results(results):
    """Print OPA decision results to the terminal."""
    for r in results:
        icon  = GREEN + "✔" + RESET if r["allow"] else RED + "✘" + RESET
        label = "PASS" if r["allow"] else ("ERROR" if r.get("error") else "BLOCK")
        color = GREEN if r["allow"] else (YELLOW if r.get("error") else RED)
        print(f"  {icon}  [{color}{label}{RESET}]  {r['domain']}: {r['reason']}")


# Host stats helpers
def get_disk_free_gb():
    usage = shutil.disk_usage("/")
    return round(usage.free / (1024 ** 3), 2)


def get_cpu_load():
    try:
        return round(os.getloadavg()[0], 2)
    except AttributeError:
        # Windows fallback
        return 0.0


# Prometheus text format parser
def parse_prometheus(text):
    """Parse Prometheus text exposition format into a dict of metric → [sample]."""
    metrics = {}
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        try:
            if "{" in line:
                name, rest  = line.split("{", 1)
                labels_str, val_part = rest.split("}", 1)
                value = float(val_part.strip().split()[0])
                labels = {}
                for pair in re.findall(r'(\w+)="([^"]*)"', labels_str):
                    labels[pair[0]] = pair[1]
            else:
                parts = line.split()
                name, value, labels = parts[0], float(parts[1]), {}
            metrics.setdefault(name.strip(), []).append(
                {"labels": labels, "value": value}
            )
        except (ValueError, IndexError):
            continue
    return metrics


def _total_requests(metrics):
    return sum(s["value"] for s in metrics.get("http_requests_total", []))


def _error_requests(metrics):
    return sum(
        s["value"]
        for s in metrics.get("http_requests_total", [])
        if s["labels"].get("status_code", "").startswith("5")
    )


def calc_error_rate_pct(metrics):
    total = _total_requests(metrics)
    if total == 0:
        return 0.0
    return round(_error_requests(metrics) / total * 100, 3)


def calc_p99_ms(metrics):
    """Estimate P99 latency in milliseconds from Prometheus histogram buckets."""
    buckets = [
        (float(s["labels"]["le"]) if s["labels"]["le"] != "+Inf" else float("inf"),
         s["value"])
        for s in metrics.get("http_request_duration_seconds_bucket", [])
    ]
    if not buckets:
        return 0.0
    buckets.sort(key=lambda x: x[0])
    total = sum(s["value"] for s in metrics.get("http_request_duration_seconds_count", []))
    if total == 0:
        return 0.0
    target    = 0.99 * total
    prev_le, prev_count = 0.0, 0.0
    for le, count in buckets:
        if count >= target:
            if count == prev_count:
                return round(prev_le * 1000, 1)
            ratio = (target - prev_count) / (count - prev_count)
            if le == float("inf"):
                return round(prev_le * 1000, 1)
            if le == float("inf"):
                return round(prev_le * 1000, 1)
            return round((prev_le + ratio * (le - prev_le)) * 1000, 1)
        prev_le, prev_count = le, count
    return round(prev_le * 1000, 1)


def _get_gauge(metrics, name):
    samples = metrics.get(name, [])
    return samples[0]["value"] if samples else None


def scrape_metrics(port):
    """Scrape /metrics from the nginx proxy and return parsed metrics dict."""
    url = f"http://localhost:{port}/metrics"
    req = urllib.request.Request(url)
    with urllib.request.urlopen(req, timeout=5) as resp:
        return parse_prometheus(resp.read().decode())


# Pre-flight OPA gate
def opa_pre_deploy_gate():
    """Query OPA infrastructure domain. Returns (all_pass, results_list)."""
    banner("OPA pre-deploy policy check")
    input_data = {
        "check_type":   "pre-deploy",
        "disk_free_gb": get_disk_free_gb(),
        "cpu_load":     get_cpu_load(),
    }
    print(f"  {DIM}disk_free={input_data['disk_free_gb']} GB  "
          f"cpu_load={input_data['cpu_load']}{RESET}")

    results = [query_opa_domain("infrastructure", input_data)]
    print_opa_results(results)
    return all(r["allow"] for r in results), results


def opa_pre_promote_gate(port):
    """
    Scrape /metrics twice (10s apart) to calculate rates,
    then query OPA canary domain. Returns (all_pass, results_list).
    """
    banner("OPA pre-promote policy check — measuring canary health (10 s) …")
    try:
        m1 = scrape_metrics(port)
        time.sleep(10)
        m2 = scrape_metrics(port)
    except Exception as e:
        fail(f"Cannot scrape /metrics: {e}")
        return False, [{"allow": False, "reason": str(e), "domain": "canary", "error": True}]

    total1, total2 = _total_requests(m1), _total_requests(m2)
    err1,   err2   = _error_requests(m1), _error_requests(m2)
    dt_total = total2 - total1

    if dt_total > 0:
        error_rate = round((err2 - err1) / dt_total * 100, 3)
    else:
        error_rate = calc_error_rate_pct(m2)

    p99 = calc_p99_ms(m2)

    input_data = {
        "check_type":      "pre-promote",
        "error_rate_pct":  error_rate,
        "p99_latency_ms":  p99,
    }
    print(f"  {DIM}error_rate={error_rate}%  p99={p99}ms{RESET}")

    results = [query_opa_domain("canary", input_data)]
    print_opa_results(results)
    return all(r["allow"] for r in results), results


# Subcommands
def cmd_init():
    banner("swiftdeploy init")
    manifest = load_manifest()
    ctx      = build_context(manifest)

    nginx_out = render_template(NGINX_TEMPLATE, ctx)
    with open(NGINX_CONF, "w") as f:
        f.write(nginx_out)
    ok(f"Generated  {NGINX_CONF}  (nginx:{ctx['nginx_port']} → service:{ctx['service_port']})")

    compose_out = render_template(COMPOSE_TEMPLATE, ctx)
    with open(COMPOSE_FILE, "w") as f:
        f.write(compose_out)
    ok(f"Generated  {COMPOSE_FILE}  (mode={ctx['mode']})")

    if not os.path.isdir(POLICIES_DIR):
        die(f"policies/ directory not found. Create it with the required .rego files.")
    ok(f"policies/ directory found ({len(os.listdir(POLICIES_DIR))} files)")

    print(f"\n  {BOLD}Init complete.{RESET}\n")


def cmd_validate():
    banner("swiftdeploy validate — 5 pre-flight checks")
    passed, failed_count = 0, 0

    def check(label, fn):
        nonlocal passed, failed_count
        try:
            success, detail = fn()
        except Exception as exc:
            success, detail = False, str(exc)
        if success:
            ok(f"[PASS]  {label}")
            passed += 1
        else:
            fail(f"[FAIL]  {label}")
            failed_count += 1
        if detail:
            for line in str(detail).splitlines():
                print(f"         {line}")

    def check_manifest():
        if not os.path.exists(MANIFEST_PATH):
            return False, "File not found."
        with open(MANIFEST_PATH) as f:
            raw = yaml.safe_load(f)
        if not isinstance(raw, dict):
            return False, "Not a valid YAML mapping."
        return True, f"Parsed OK ({len(raw)} top-level keys)."

    def check_fields():
        m = load_manifest()
        required = {
            "services.image":      m.get("services", {}).get("image"),
            "services.port":       m.get("services", {}).get("port"),
            "nginx.image":         m.get("nginx",    {}).get("image"),
            "nginx.port":          m.get("nginx",    {}).get("port"),
            "network.name":        m.get("network",  {}).get("name"),
            "network.driver_type": m.get("network",  {}).get("driver_type"),
        }
        missing = [k for k, v in required.items() if v is None]
        if missing:
            return False, "Missing: " + ", ".join(missing)
        return True, "\n".join(f"{k} = {v}" for k, v in required.items())

    def check_image():
        m     = load_manifest()
        image = m.get("services", {}).get("image", "")
        r     = run(f"docker image inspect {image}", capture=True, check=False)
        if r.returncode != 0:
            return False, f"Image '{image}' not found. Build it first."
        return True, f"Image '{image}' present."

    def check_port():
        m    = load_manifest()
        port = int(m.get("nginx", {}).get("port", 8080))
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            s.settimeout(1)
            in_use = s.connect_ex(("127.0.0.1", port)) == 0
        if in_use:
            return False, f"Port {port} already in use."
        return True, f"Port {port} is free."

    def check_nginx_syntax():
        if not os.path.exists(NGINX_CONF):
            return False, f"'{NGINX_CONF}' not found — run init first."
        tmp = "/tmp/swiftdeploy_nginx.conf"
        shutil.copy(os.path.abspath(NGINX_CONF), tmp)
        tmp_content = open(tmp).read().replace("service:", "127.0.0.1:")
        open(tmp, "w").write(tmp_content)
        r = run(
            f"docker run --rm -v {tmp}:/etc/nginx/conf.d/default.conf:ro "
            f"nginx:latest nginx -t 2>&1",
            capture=True, check=False,
        )
        os.remove(tmp)
        output = (r.stdout + r.stderr).strip()
        if r.returncode != 0:
            return False, f"nginx -t failed:\n{output}"
        return True, "nginx -t passed."

    check("manifest.yaml exists and is valid YAML",             check_manifest)
    check("All required fields are present and non-empty",      check_fields)
    check("Docker image referenced in manifest exists locally", check_image)
    check("Nginx port is not already bound on the host",        check_port)
    check("Generated nginx.conf is syntactically valid",        check_nginx_syntax)

    total = passed + failed_count
    color = GREEN if failed_count == 0 else RED
    print(f"\n  {color}{BOLD}Result: {passed}/{total} checks passed.{RESET}\n")
    if failed_count:
        sys.exit(1)


def cmd_deploy():
    banner("swiftdeploy deploy")
    cmd_init()

    # Start OPA first so we can run pre-deploy checks
    banner("Starting OPA …")
    run("docker compose up -d opa")

    print("  Waiting for OPA to be ready …")
    deadline = time.time() + 30
    opa_ready = False
    while time.time() < deadline:
        try:
            with urllib.request.urlopen(f"{OPA_URL}/health", timeout=2) as r:
                if r.status == 200:
                    opa_ready = True
                    break
        except Exception:
            pass
        time.sleep(2)

    if not opa_ready:
        warn("OPA did not become ready in 30 s — proceeding without policy gate.")
    else:
        ok("OPA is ready.")
        # Pre-deploy OPA gate
        all_pass, results = opa_pre_deploy_gate()
        if not all_pass:
            print()
            die("Deploy BLOCKED by policy. Resolve violations and retry.")

    # Bring up the full stack
    banner("Bringing up stack …")
    run("docker compose up -d")

    manifest = load_manifest()
    port     = int(manifest.get("nginx", {}).get("port", 8080))
    url      = f"http://localhost:{port}/healthz"

    print(f"\n  Waiting for service at {url} (60 s timeout) …\n")
    deadline = time.time() + 60
    while time.time() < deadline:
        try:
            with urllib.request.urlopen(url, timeout=3) as resp:
                if resp.status == 200:
                    body = json.loads(resp.read())
                    ok(f"Health check passed!  uptime={body.get('uptime','?')}s")
                    print(f"\n  {GREEN}{BOLD}Stack deployed successfully.{RESET}\n")
                    return
        except Exception:
            pass
        sys.stdout.write(".")
        sys.stdout.flush()
        time.sleep(2)

    print()
    die("Health check timed out after 60 s. Run: docker compose logs")


def cmd_promote(mode):
    if mode not in ("stable", "canary"):
        die(f"Invalid mode '{mode}'. Use: swiftdeploy promote [canary|stable]")

    banner(f"swiftdeploy promote → {mode}")

    manifest     = load_manifest()
    port         = int(manifest.get("nginx", {}).get("port", 8080))
    current_mode = manifest.get("services", {}).get("mode", "stable")

    if current_mode == mode:
        warn(f"Already in '{mode}' mode — nothing to do.")
        return

    # Pre-promote OPA gate (only when promoting to stable)
    if mode == "stable":
        all_pass, _ = opa_pre_promote_gate(port)
        if not all_pass:
            print()
            die("Promotion BLOCKED by canary safety policy.")

    # Update manifest in-place
    with open(MANIFEST_PATH) as f:
        content = f.read()

    if re.search(r"^\s+mode\s*:", content, re.MULTILINE):
        updated = re.sub(
            r"^(\s+mode\s*:\s*)\S+",
            lambda m: m.group(1) + mode,
            content, flags=re.MULTILINE,
        )
    else:
        updated = re.sub(
            r"(^services\s*:.*?)(\n\S)",
            lambda m: m.group(1) + f"\n  mode: {mode}" + m.group(2),
            content, flags=re.DOTALL,
        )

    with open(MANIFEST_PATH, "w") as f:
        f.write(updated)
    ok(f"manifest.yaml updated: mode = {current_mode} → {mode}")

    new_manifest = load_manifest()
    ctx          = build_context(new_manifest)
    with open(COMPOSE_FILE, "w") as f:
        f.write(render_template(COMPOSE_TEMPLATE, ctx))
    ok("docker-compose.yml regenerated.")

    banner("Restarting service container …")
    run("docker compose up -d --no-deps --force-recreate service")

    print(f"\n  Verifying mode switch at http://localhost:{port}/healthz …\n")
    time.sleep(3)
    deadline = time.time() + 30
    while time.time() < deadline:
        try:
            req = urllib.request.Request(f"http://localhost:{port}/healthz")
            with urllib.request.urlopen(req, timeout=3) as resp:
                if resp.status == 200:
                    x_mode = resp.headers.get("X-Mode", "stable")
                    body   = json.loads(resp.read())
                    if mode == "canary":
                        ok(f"Mode confirmed: canary  (X-Mode: canary ✔)  uptime={body.get('uptime','?')}s")
                    else:
                        ok(f"Mode confirmed: stable  uptime={body.get('uptime','?')}s")
                    print(f"\n  {GREEN}{BOLD}Promotion to '{mode}' complete.{RESET}\n")
                    return
        except Exception:
            pass
        sys.stdout.write(".")
        sys.stdout.flush()
        time.sleep(2)
    print()
    die("Could not confirm mode switch within 30 s.")


def cmd_status():
    """Live-refreshing terminal dashboard. Ctrl+C to exit."""
    banner("swiftdeploy status — live dashboard (Ctrl+C to exit)")

    manifest = load_manifest()
    port     = int(manifest.get("nginx", {}).get("port", 8080))

    prev_metrics = None
    prev_time    = None

    try:
        while True:
            os.system("clear")
            now = time.time()
            ts  = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime(now))

            # Scrape metrics
            try:
                metrics = scrape_metrics(port)
                scrape_ok = True
            except Exception as e:
                metrics, scrape_ok = {}, False
                scrape_err = str(e)

            # Calculate rates
            req_s      = None
            error_rate = 0.0
            p99        = 0.0

            if scrape_ok:
                if prev_metrics and prev_time:
                    dt = now - prev_time
                    if dt > 0:
                        req_s = round(
                            (_total_requests(metrics) - _total_requests(prev_metrics)) / dt, 2
                        )
                error_rate = calc_error_rate_pct(metrics)
                p99        = calc_p99_ms(metrics)

            # Read mode / chaos from gauges
            mode_val  = _get_gauge(metrics, "app_mode")
            chaos_val = _get_gauge(metrics, "chaos_active")
            mode      = "canary" if mode_val == 1 else "stable"
            chaos     = {0: "none", 1: "slow", 2: "error"}.get(
                int(chaos_val or 0), "none"
            )

            # Query OPA for compliance
            opa_infra  = query_opa_domain("infrastructure", {
                "check_type":   "status",
                "disk_free_gb": get_disk_free_gb(),
                "cpu_load":     get_cpu_load(),
            })
            opa_canary = query_opa_domain("canary", {
                "check_type":      "status",
                "error_rate_pct":  error_rate,
                "p99_latency_ms":  p99 if p99 != float("inf") else 0.0,
            })
            opa_results = [opa_infra, opa_canary]

            # Print dashboard
            W = 62
            print(f"\n{BOLD}{'SwiftDeploy Status Dashboard':^{W}}{RESET}")
            print("─" * W)
            mc = YELLOW if mode == "canary" else GREEN
            cc = RED if chaos != "none" else GREEN
            print(f"  Mode: {mc}{BOLD}{mode}{RESET}     Chaos: {cc}{chaos}{RESET}")
            print()

            print(f"  {'Performance':─<{W-4}}")
            if scrape_ok:
                rps_str = f"{req_s:.2f} req/s" if req_s is not None else "—"
                print(f"  Req/s         {rps_str}")
                print(f"  P99 Latency   {p99:.0f} ms")
                print(f"  Error Rate    {error_rate:.3f} %")
            else:
                print(f"  {RED}Cannot scrape /metrics: {scrape_err}{RESET}")
            print()

            print(f"  {'Policy Compliance':─<{W-4}}")
            for r in opa_results:
                icon  = f"{GREEN}✔{RESET}" if r["allow"] else f"{RED}✘{RESET}"
                color = GREEN if r["allow"] else (YELLOW if r.get("error") else RED)
                label = "PASS" if r["allow"] else ("ERR" if r.get("error") else "FAIL")
                print(f"  {icon} [{color}{label}{RESET}] {r['domain']}: {DIM}{r['reason']}{RESET}")
            print()
            print(f"  {DIM}Updated: {ts}   Refresh: {STATUS_INTERVAL}s{RESET}")
            print(f"  {DIM}History: {HISTORY_FILE}{RESET}")
            print("─" * W)

            # Append to history.jsonl
            record = {
                "timestamp":      ts,
                "req_s":          req_s,
                "p99_latency_ms": p99,
                "error_rate_pct": error_rate,
                "mode":           mode,
                "chaos":          chaos,
                "disk_free_gb":   get_disk_free_gb(),
                "cpu_load":       get_cpu_load(),
                "policies": {
                    r["domain"]: {"allow": r["allow"], "reason": r["reason"]}
                    for r in opa_results
                },
            }
            with open(HISTORY_FILE, "a") as f:
                f.write(json.dumps(record) + "\n")

            prev_metrics = metrics
            prev_time    = now
            time.sleep(STATUS_INTERVAL)

    except KeyboardInterrupt:
        print(f"\n\n  Status dashboard stopped. History saved to {HISTORY_FILE}\n")


def cmd_audit():
    """Generate audit_report.md from history.jsonl."""
    banner("swiftdeploy audit")

    if not os.path.exists(HISTORY_FILE):
        die(f"{HISTORY_FILE} not found. Run 'swiftdeploy status' first to collect data.")

    records = []
    with open(HISTORY_FILE) as f:
        for line in f:
            line = line.strip()
            if line:
                try:
                    records.append(json.loads(line))
                except json.JSONDecodeError:
                    continue

    if not records:
        die(f"{HISTORY_FILE} is empty.")

    ok(f"Loaded {len(records)} records from {HISTORY_FILE}")

    # Build sections
    first_ts = records[0]["timestamp"]
    last_ts  = records[-1]["timestamp"]

    # Timeline table (last 20 records for readability)
    timeline_rows = []
    for r in records[-20:]:
        timeline_rows.append(
            f"| {r['timestamp']} "
            f"| {r.get('mode','?')} "
            f"| {r.get('chaos','?')} "
            f"| {r.get('req_s') or '—'} "
            f"| {r.get('p99_latency_ms') or '—'} "
            f"| {r.get('error_rate_pct') or '—'} |"
        )

    # Mode changes
    mode_changes = []
    prev_mode = None
    for r in records:
        m = r.get("mode", "stable")
        if prev_mode and m != prev_mode:
            mode_changes.append(f"| {r['timestamp']} | {prev_mode} | {m} |")
        prev_mode = m

    # Chaos events
    chaos_events = []
    prev_chaos = None
    for r in records:
        c = r.get("chaos", "none")
        if c != "none" and c != prev_chaos:
            chaos_events.append(f"| {r['timestamp']} | {c} |")
        prev_chaos = c

    # Policy violations
    violations = []
    for r in records:
        for domain, result in r.get("policies", {}).items():
            if not result.get("allow", True):
                violations.append(
                    f"| {r['timestamp']} | {domain} | {result.get('reason','?')} |"
                )

    # Write markdown
    report_path = "audit_report.md"
    lines = [
        "# SwiftDeploy Audit Report",
        "",
        f"**Generated:** {time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime())}  ",
        f"**Records:** {len(records)} scrapes  ",
        f"**Window:** {first_ts} → {last_ts}",
        "",
        "---",
        "",
        "## Timeline (last 20 scrapes)",
        "",
        "| Timestamp | Mode | Chaos | Req/s | P99 (ms) | Error Rate % |",
        "|-----------|------|-------|-------|----------|--------------|",
        *timeline_rows,
        "",
        "---",
        "",
        "## Mode Changes",
        "",
    ]

    if mode_changes:
        lines += [
            "| Timestamp | From | To |",
            "|-----------|------|----|",
            *mode_changes,
        ]
    else:
        lines.append("_No mode changes recorded._")

    lines += [
        "",
        "---",
        "",
        "## Chaos Events",
        "",
    ]

    if chaos_events:
        lines += [
            "| Timestamp | Type |",
            "|-----------|------|",
            *chaos_events,
        ]
    else:
        lines.append("_No chaos events recorded._")

    lines += [
        "",
        "---",
        "",
        "## Policy Violations",
        "",
    ]

    if violations:
        lines += [
            "| Timestamp | Domain | Reason |",
            "|-----------|--------|--------|",
            *violations,
        ]
    else:
        lines.append("_No policy violations recorded._")

    lines += ["", "---", "", f"_Generated by swiftdeploy audit_", ""]

    with open(report_path, "w") as f:
        f.write("\n".join(lines))

    ok(f"Report written to {report_path}")
    print(f"\n  Open in GitHub or any Markdown viewer for formatted output.\n")


def cmd_teardown(clean=False):
    banner("swiftdeploy teardown")
    run("docker compose down --volumes --remove-orphans", check=False)
    ok("Containers, networks, and volumes removed.")
    if clean:
        for path in [NGINX_CONF, COMPOSE_FILE]:
            if os.path.exists(path):
                os.remove(path)
                ok(f"Deleted: {path}")
        print(f"\n  {GREEN}{BOLD}Clean teardown complete.{RESET}\n")
    else:
        print(f"\n  {BOLD}Teardown complete.{RESET}  (--clean also deletes generated configs)\n")


# Entry point
USAGE = f"""
{BOLD}swiftdeploy{RESET} — declarative container deployment tool (Stage 4B)

{BOLD}Usage:{RESET}
  ./swiftdeploy init
  ./swiftdeploy validate
  ./swiftdeploy deploy
  ./swiftdeploy promote [canary|stable]
  ./swiftdeploy status
  ./swiftdeploy audit
  ./swiftdeploy teardown [--clean]
"""

def main():
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help", "help"):
        print(USAGE)
        sys.exit(0)

    cmd = args[0]

    if   cmd == "init":     cmd_init()
    elif cmd == "validate": cmd_validate()
    elif cmd == "deploy":   cmd_deploy()
    elif cmd == "promote":
        if len(args) < 2:
            die("Usage: swiftdeploy promote [canary|stable]")
        cmd_promote(args[1])
    elif cmd == "status":   cmd_status()
    elif cmd == "audit":    cmd_audit()
    elif cmd == "teardown": cmd_teardown(clean="--clean" in args)
    else:
        fail(f"Unknown command: {cmd!r}")
        print(USAGE)
        sys.exit(1)

if __name__ == "__main__":
    main()
